generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// D-01: Multiple equal teachers; no role table in v1 — extend here for future RBAC.
model Teacher {
  id                     String                @id @default(cuid())
  username               String                @unique
  passwordHash           String
  displayName            String
  mustChangePassword     Boolean               @default(true)
  showSeatBoard          Boolean               @default(true)
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  questionImportBatches   QuestionImportBatch[]
  fillInImportBatches     FillInQuestionImportBatch[]
  rosterImportBatches     RosterImportBatch[]
  exams                   Exam[]
}

enum QuestionType {
  SINGLE
  MULTI
  JUDGE
  FILL
}

enum MultiScoringRule {
  ALL_OR_NOTHING
}

model QuestionImportBatch {
  id            String     @id @default(cuid())
  teacherId     String
  teacher       Teacher    @relation(fields: [teacherId], references: [id])
  fileName      String
  totalRows     Int
  importedCount Int
  skippedCount  Int        @default(0)
  createdAt     DateTime   @default(now())
  questions     Question[]
  exams         Exam[]

  @@index([teacherId])
}

model Question {
  id               String              @id @default(cuid())
  batchId          String?
  batch            QuestionImportBatch? @relation(fields: [batchId], references: [id], onDelete: Cascade)
  fillInBatchId    String?
  fillInBatch      FillInQuestionImportBatch? @relation(fields: [fillInBatchId], references: [id], onDelete: Cascade)
  type             QuestionType
  stem             String
  answerKeys       String
  points           Float               @default(1)
  difficulty       Int                 @default(1)
  explanation      String?
  knowledgePoints  String?
  multiScoringRule MultiScoringRule?
  /** Excel 行序（0-based）；组卷与列表按此排序，勿用 createdAt */
  importSortOrder  Int                 @default(0)
  createdAt        DateTime            @default(now())
  options          QuestionOption[]
  examQuestions    ExamQuestion[]

  @@index([batchId])
  @@index([batchId, importSortOrder])
  @@index([fillInBatchId])
  @@index([fillInBatchId, importSortOrder])
  @@index([type])
}

model QuestionOption {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  key        String
  text       String
  sortOrder  Int

  @@unique([questionId, key])
}

model RosterImportBatch {
  id            String        @id @default(cuid())
  teacherId     String
  teacher       Teacher       @relation(fields: [teacherId], references: [id])
  fileName      String
  totalRows     Int
  importedCount Int
  skippedCount  Int           @default(0)
  createdAt     DateTime      @default(now())
  entries       RosterEntry[]
  exams         Exam[]

  @@index([teacherId])
}

model RosterEntry {
  id           String            @id @default(cuid())
  batchId      String
  batch        RosterImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  fullName     String
  organization String
  nationalId   String
  createdAt    DateTime          @default(now())
  submissions            Submission[]
  answerDrafts           AnswerDraft[]
  fillInScreenshotDrafts FillInScreenshotDraft[]
  examSeatAssignments    ExamSeatAssignment[]

  @@unique([batchId, fullName, nationalId])
  @@index([fullName])
  @@index([nationalId])
}

enum ExamStatus {
  DRAFT
  IN_PROGRESS
  ENDED
}

enum ExamContentModule {
  OBJECTIVE
  FILL
}

model FillInQuestionImportBatch {
  id                     String                  @id @default(cuid())
  teacherId              String
  teacher                Teacher                 @relation(fields: [teacherId], references: [id])
  title                  String
  wordFileName           String
  wordStorageKey         String
  /** 考官原卷（含标准答案），不对外下发 */
  sourceWordStorageKey   String?
  excelFileName          String?
  excelStorageKey        String?
  studentExcelStorageKey String?
  /** @deprecated 仅旧数据；新导入写入 FillInBatchAttachment */
  attachmentFileName     String?
  /** @deprecated 仅旧数据；新导入写入 FillInBatchAttachment */
  attachmentStorageKey   String?
  importedCount          Int
  createdAt              DateTime                @default(now())
  attachments            FillInBatchAttachment[]
  questions              Question[]
  exams                  Exam[]

  @@index([teacherId])
}

model FillInBatchAttachment {
  id          String                    @id @default(cuid())
  batchId     String
  batch       FillInQuestionImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  fileName    String
  storageKey  String
  sortOrder   Int
  createdAt   DateTime                  @default(now())

  @@index([batchId])
}

model Exam {
  id               String            @id @default(cuid())
  title            String
  status           ExamStatus        @default(DRAFT)
  contentModules   ExamContentModule[]
  teacherId        String
  teacher          Teacher           @relation(fields: [teacherId], references: [id])
  questionBatchId  String?
  questionBatch    QuestionImportBatch? @relation(fields: [questionBatchId], references: [id])
  fillInBatchId    String?
  fillInBatch      FillInQuestionImportBatch? @relation(fields: [fillInBatchId], references: [id])
  rosterBatchId    String
  rosterBatch      RosterImportBatch @relation(fields: [rosterBatchId], references: [id])
  scheduledStartAt DateTime?
  scheduledEndAt   DateTime?
  startedAt        DateTime?
  endedAt          DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  questions            ExamQuestion[]
  submissions          Submission[]
  answerDrafts         AnswerDraft[]
  fillInScreenshotDrafts FillInScreenshotDraft[]
  seatAssignments        ExamSeatAssignment[]

  @@index([status])
  @@index([rosterBatchId])
  @@index([questionBatchId])
  @@index([fillInBatchId])
}

model ExamQuestion {
  id         String   @id @default(cuid())
  examId     String
  exam       Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  questionId String
  question   Question @relation(fields: [questionId], references: [id])
  sortOrder  Int
  answers    Answer[]
  answerDrafts AnswerDraft[]
  fillInScreenshotDrafts FillInScreenshotDraft[]

  @@unique([examId, questionId])
  @@index([examId, sortOrder])
}

model Submission {
  id            String      @id @default(cuid())
  examId        String
  exam          Exam        @relation(fields: [examId], references: [id], onDelete: Cascade)
  rosterEntryId String
  rosterEntry   RosterEntry @relation(fields: [rosterEntryId], references: [id])
  totalScore    Float
  submittedAt   DateTime    @default(now())
  answers       Answer[]
  fillInScreenshots FillInScreenshot[]

  @@unique([examId, rosterEntryId])
  @@index([examId])
}

model FillInScreenshotDraft {
  id               String       @id @default(cuid())
  examId           String
  exam             Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  rosterEntryId    String
  rosterEntry      RosterEntry  @relation(fields: [rosterEntryId], references: [id], onDelete: Cascade)
  examQuestionId   String
  examQuestion     ExamQuestion @relation(fields: [examQuestionId], references: [id], onDelete: Cascade)
  sortOrder        Int
  storageKey       String
  mimeType         String
  byteSize         Int
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([examId, rosterEntryId, examQuestionId, sortOrder])
  @@index([examId, rosterEntryId])
}

model FillInScreenshot {
  id               String       @id @default(cuid())
  submissionId     String
  submission       Submission   @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  examQuestionId   String
  sortOrder        Int
  storageKey       String
  mimeType         String
  byteSize         Int

  @@unique([submissionId, examQuestionId, sortOrder])
  @@index([submissionId])
}

model Answer {
  id             String       @id @default(cuid())
  submissionId   String
  submission     Submission   @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  examQuestionId String
  examQuestion   ExamQuestion @relation(fields: [examQuestionId], references: [id], onDelete: Cascade)
  selectedKeys   String
  isCorrect      Boolean
  pointsAwarded  Float

  @@unique([submissionId, examQuestionId])
}

model AnswerDraft {
  id             String       @id @default(cuid())
  examId         String
  exam           Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  rosterEntryId  String
  rosterEntry    RosterEntry  @relation(fields: [rosterEntryId], references: [id], onDelete: Cascade)
  examQuestionId String
  examQuestion   ExamQuestion @relation(fields: [examQuestionId], references: [id], onDelete: Cascade)
  selectedKeys   String
  updatedAt      DateTime     @updatedAt

  @@unique([examId, rosterEntryId, examQuestionId])
  @@index([examId, rosterEntryId])
}

model ExamSeatAssignment {
  id            String      @id @default(cuid())
  examId        String
  exam          Exam        @relation(fields: [examId], references: [id], onDelete: Cascade)
  rosterEntryId String
  rosterEntry   RosterEntry @relation(fields: [rosterEntryId], references: [id], onDelete: Cascade)
  seatLabel     String
  displayOrder  Int
  createdAt     DateTime    @default(now())

  @@unique([examId, rosterEntryId])
  @@unique([examId, seatLabel])
  @@index([examId, displayOrder])
}
