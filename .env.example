# PostgreSQL (Compose service hostname `db` inside stack; use localhost when DB port is published)
DATABASE_URL=postgresql://lan_exam:lan_exam_dev@localhost:5434/lan_exam

# Docker Compose host port mapping（Linux 公网测试固定 8001，见 scripts/linux/deploy-docker.sh）
# WEB_HOST_PORT=8001
# DB_HOST_PORT=5434

# Dev server ports (defaults avoid common 3001/5173/5432 conflicts on Windows)
API_PORT=3101
WEB_PORT=5180
LISTEN_HOST=0.0.0.0

# Admin auth: disabled = 机房免登录（local_exam_admin）；session = 考官账号登录（开发/回退）
ADMIN_AUTH_MODE=disabled
LOCAL_ADMIN_USERNAME=local_exam_admin
# 默认 true；机房安装包不应关闭
ADMIN_API_LOOPBACK_ONLY=true

# Required when ADMIN_AUTH_MODE=session — never commit real values
SEED_ADMIN_PASSWORD=

# Session cookie signing (min 16 chars; required in production)
SESSION_SECRET=

# Production native / Docker full stack: NODE_ENV=production serves web on WEB_PORT
# SERVE_WEB=true
# WEB_DIST_PATH=

# Vite (apps/web): must match ADMIN_AUTH_MODE — disabled = skip admin login UI
VITE_ADMIN_AUTH_MODE=disabled
# session 回退时删除上一行或改为非 disabled，并设 ADMIN_AUTH_MODE=session

# 上传与衍生文件根目录（操作题批次、学员答卷、exam-work）；Compose 见 docker-compose DATA_DIR
# DATA_DIR=data

# Word 上传上限（字节，默认 20MB；操作题 Word 题目，历史变量名 MAX_PRACTICAL_DOCX_BYTES）
# MAX_PRACTICAL_DOCX_BYTES=20971520

# Excel 上传上限（字节，默认 10MB；操作题 Excel / 名单 / 客观题导入，历史变量名 MAX_PRACTICAL_XLSX_BYTES）
# MAX_PRACTICAL_XLSX_BYTES=10485760

# 操作题每空截图上限（字节，默认 5MB）；格式 PNG/JPEG/WebP，每空最多 5 张（代码常量）
# MAX_FILLIN_SCREENSHOT_BYTES=5242880

# Fastify multipart 单文件上限（须 ≥ 操作题附件(默认合计1GB内单文件)、截图等；未设时取各类上限最大值，含操作题附件 1GB）
# MULTIPART_MAX_FILE_BYTES=1073741824

# 考场削峰：拉卷并发门控、交卷 FIFO 队列、Session 连接池（可选，见 apps/server/src/lib/env.ts 默认值）
# EXAM_PAPER_MAX_CONCURRENT=16
# EXAM_SUBMIT_MAX_CONCURRENT=4
# EXAM_SUBMIT_MAX_QUEUE=128
# EXAM_SYNC_MAX_CONCURRENT=8
# EXAM_SYNC_MAX_QUEUE=256
# SESSION_PG_POOL_MAX=10
# Prisma 连接池可在 DATABASE_URL 追加，例如：
# DATABASE_URL=postgresql://user:pass@localhost:5434/lan_exam?connection_limit=25&pool_timeout=10
