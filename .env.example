# PostgreSQL (Compose service hostname `db` inside stack; use localhost when DB port is published)
DATABASE_URL=postgresql://lan_exam:lan_exam_dev@localhost:5432/lan_exam

# Required for `pnpm exec prisma db seed` / Compose first boot — never commit real values
SEED_ADMIN_PASSWORD=

# Session cookie signing (min 16 chars; required in production)
SESSION_SECRET=
