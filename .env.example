# PostgreSQL (Compose service hostname `db` inside stack; use localhost when DB port is published)
DATABASE_URL=postgresql://lan_exam:lan_exam_dev@localhost:5434/lan_exam

# Dev server ports (defaults avoid common 3001/5173/5432 conflicts on Windows)
API_PORT=3101
WEB_PORT=5180
LISTEN_HOST=0.0.0.0

# Admin auth: disabled = 机房免登录（local_exam_admin）；session = 考官账号登录（开发/回退）
ADMIN_AUTH_MODE=disabled
LOCAL_ADMIN_USERNAME=local_exam_admin
# 默认 true；机房安装包不应关闭
ADMIN_API_LOOPBACK_ONLY=true

# Required when ADMIN_AUTH_MODE=session — never commit real values
SEED_ADMIN_PASSWORD=

# Session cookie signing (min 16 chars; required in production)
SESSION_SECRET=

# Production native / Docker full stack: NODE_ENV=production serves web on WEB_PORT
# SERVE_WEB=true
# WEB_DIST_PATH=

# Vite (apps/web): must match ADMIN_AUTH_MODE — disabled = skip admin login UI
VITE_ADMIN_AUTH_MODE=disabled
# session 回退时删除上一行或改为非 disabled，并设 ADMIN_AUTH_MODE=session
